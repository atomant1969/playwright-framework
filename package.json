{
  "name": "playwright-framework",
  "version": "1.0.0",
  "private": true,
  "description": "Config-driven Playwright suite framework with sequential, parallel, and hybrid execution modes.",
  "type": "commonjs",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "postinstall": "playwright install",
    "test": "playwright test",
    "test:suite": "playwright test",
    "test:parallel": "cross-env TEST_SUITE=parallel playwright test",
    "test:ui": "playwright test --ui",
    "admin": "tsx scripts/admin-console.ts",
    "doctor": "tsx scripts/doctor.ts",
    "typecheck": "tsc --noEmit",
    "validate:suites": "tsx scripts/validate-suites.ts",
    "suite:summary": "tsx scripts/generate-suite-summary.ts",
    "suite:results": "tsx scripts/generate-suite-result-summary.ts",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "browsers:install": "playwright install",
    "allure:generate": "allure generate allure-results -o allure-report --clean",
    "matrix": "tsx scripts/generate-suite-matrix.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@playwright/test": "^1.50.1",
    "@types/node": "^22.10.7",
    "allure-commandline": "^2.32.2",
    "allure-playwright": "^3.1.0",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.7",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "winston": "^3.17.0"
  },
  "packageManager": "pnpm@9.15.4+sha512.b2dc20e2fc72b3e18848459b37359a32064663e5627a51e4c74b2c29dd8e8e0491483c3abb40789cfd578bf362fb6ba8261b05f0387d76792ed6e23ea3b1b6a0"
}
