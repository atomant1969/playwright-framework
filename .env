# Dummy defaults committed so a fresh clone can run immediately.
# Replace values locally or override them in CI environment variables.

TEST_SUITE=smoke
PARALLEL_SUITE_KEYS=smoke,api_smoke
SUITE_EXECUTION_MODE=serial

BASE_URL=https://example.com
API_BASE_URL=https://example.com
HEADLESS=true
TIMEZONE_ID=UTC
LOG_LEVEL=info
RETRIES=0
PLAYWRIGHT_WORKERS=3

LOGIN_ENABLED=false
LOGIN_USERNAME=dummy-user
LOGIN_PASSWORD=dummy-password
LOGIN_TABEL=0000
